# ============================================
# ExtraHand Main Admin Service - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=4007
LOG_LEVEL=info

# ============================================
# Database Configuration
# ============================================
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/extrahand
# MongoDB database name
MONGO_DB=extrahand
# KycSession documents live in the verification-service database (not MONGO_DB)
KYC_VERIFICATION_DB=extrahand_verifications

# ============================================
# KYC Vault / MinIO (Aadhaar review photos)
# ============================================
MINIO_ENDPOINT=https://your-minio-host
MINIO_SERVER_URL=https://your-minio-host
MINIO_ROOT_USER=your-minio-access-key
MINIO_ROOT_PASSWORD=your-minio-secret-key
MINIO_REGION_NAME=us-east-1
KYC_VAULT_BUCKET_NAME=extrahand-kyc-vault

# ============================================
# JWT Authentication
# ============================================
# JWT secret for access tokens (minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
# JWT secret for refresh tokens (minimum 32 characters)
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-minimum-32-characters-long
# Access token expiry (default: 15m)
JWT_ACCESS_EXPIRY=15m
# Refresh token expiry (default: 7d)
JWT_REFRESH_EXPIRY=7d

# ============================================
# Microsoft OAuth (Optional)
# ============================================
# Uncomment and fill if using Microsoft OAuth for admin login
# MICROSOFT_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# MICROSOFT_TENANT_ID=your-microsoft-tenant-id
# MICROSOFT_REDIRECT_URI=http://localhost:4007/api/v1/auth/microsoft/callback

# ============================================
# Frontend URLs
# ============================================
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:3000,http://localhost:3001,http://localhost:3002
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002
# Admin Dashboard URL (for CORS and redirects)
ADMIN_DASHBOARD_URL=http://localhost:3000
# Main Admin Dashboard URL
MAIN_ADMIN_DASHBOARD_URL=http://localhost:3001
# Super Admin Dashboard URL
SUPER_ADMIN_DASHBOARD_URL=http://localhost:3002

# ============================================
# External Service URLs
# ============================================
# User Service URL (for user management operations)
USER_SERVICE_URL=http://localhost:4001
# Task Service URL (for task management operations)
TASK_SERVICE_URL=http://localhost:4002
# Payment Service URL (for payment operations - optional)
# PAYMENT_SERVICE_URL=http://localhost:4003
# Support Service URL (for support ticket/article management)
SUPPORT_SERVICE_URL=http://localhost:4006

# ============================================
# Service Authentication
# ============================================
# Shared secret token for inter-service communication (minimum 32 characters)
# This token is used to authenticate requests between services
# MUST exactly match SERVICE_AUTH_TOKEN on user-service and task-service (their gateway
# middleware rejects mismatches with HTTP 401; the admin API maps that to 502 so the SPA
# does not treat it as an expired admin JWT).
SERVICE_AUTH_TOKEN=your-shared-secret-token-for-service-to-service-auth-min-32-chars

# ============================================
# Email Service (Optional)
# ============================================
# Email service URL for sending admin invites
# EMAIL_SERVICE_URL=http://localhost:4005

# ============================================
# Admin Notifications (Optional)
# ============================================
# Send in-app admin notifications only to a specific admin userId
# ADMIN_NOTIFICATION_USER_ID=admin_1234567890_abcdef

# ============================================
# Production Notes
# ============================================
# For production:
# 1. Set NODE_ENV=production
# 2. Use strong, randomly generated secrets for JWT_SECRET, JWT_REFRESH_SECRET, and SERVICE_AUTH_TOKEN
# 3. Update all URLs to production endpoints
# 4. Ensure MongoDB URI points to production database
# 5. Set appropriate LOG_LEVEL (error, warn, info, or debug)

# ============================================
# Example Production Values
# ============================================
# NODE_ENV=production
# PORT=4007
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/extrahand?retryWrites=true&w=majority
# ADMIN_DASHBOARD_URL=https://admin.extrahand.in
# MAIN_ADMIN_DASHBOARD_URL=https://main-admin.extrahand.in
# USER_SERVICE_URL=https://extrahand-user-service.apps.extrahand.in
# TASK_SERVICE_URL=https://extrahand-task-service.apps.extrahand.in
# SUPPORT_SERVICE_URL=https://extrahand-platform-support-service.apps.extrahand.in

# ============================================
# Super Admin Seed (Optional)
# ============================================
# These are used by the seed script to create the initial super admin
# If not provided, defaults will be used
# SUPER_ADMIN_EMAIL=admin@extrahand.in
# SUPER_ADMIN_PASSWORD=Admin@123
# SUPER_ADMIN_NAME=Super Admin
