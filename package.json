{
  "name": "extrahand-main-admin-service",
  "version": "1.0.0",
  "description": "Main Admin Service - Auth, Super Admin, and Platform Operations",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prod": "NODE_ENV=production node dist/server.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "seed:super-admin": "ts-node scripts/seed-super-admin.ts",
    "list:kyc-vault": "ts-node scripts/list-kyc-vault-images.ts",
    "list:kyc-vault:open": "ts-node scripts/list-kyc-vault-images.ts --open",
    "repair:aadhaar-assignments": "ts-node scripts/repair-aadhaar-kyc-assignments.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.8.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pg": "^8.16.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.15.4",
    "@types/uuid": "^9.0.8",
    "prisma": "7.8.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
